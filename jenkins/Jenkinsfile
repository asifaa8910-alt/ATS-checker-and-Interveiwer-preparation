pipeline {
    agent any

    environment {
        DOCKER_IMAGE_BACKEND = 'interviewai-backend'
        DOCKER_IMAGE_FRONTEND = 'interviewai-frontend'
    }

    stages {
        stage('Clone Repository') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installing frontend dependencies...'
                dir('frontend') {
                    sh 'npm install'
                }
                echo 'Installing backend dependencies...'
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Linting') {
            steps {
                echo 'Running linting...'
                dir('frontend') {
                    sh 'npm run lint || true'
                }
            }
        }

        stage('Run Tests') {
            steps {
                echo 'Running tests...'
                dir('backend') {
                    sh 'npm test || true'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                echo 'Building frontend...'
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Build Backend') {
            steps {
                echo 'Building backend...'
                dir('backend') {
                    sh 'node --check src/server.js'
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo 'Building docker images...'
                sh 'docker compose build'
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                echo 'Deploying application...'
                sh 'sh jenkins/deploy.sh'
            }
        }

        stage('Verify Deployment') {
            steps {
                echo 'Running health check...'
                sh 'curl --retry 5 --retry-delay 5 http://localhost:3000 || curl -k http://localhost:3000'
            }
        }
    }
}
